{
  "name": "gfless",
  "version": "1.0.0",
  "description": "A Node.js library for generating device fingerprints and blackbox data for authentication purposes. Qt-free port of the original GflessClient authentication system.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*",
    "binding.gyp",
    "src/**/*"
  ],
  "scripts": {
    "build": "npm run build:native && npm run build:ts",
    "build:native": "node-gyp rebuild",
    "build:ts": "tsc",
    "clean": "rimraf lib && node-gyp clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run clean && npm run build",
    "install": "node-gyp rebuild"
  },
  "keywords": [
    "gameforge",
    "authentication",
    "fingerprint",
    "blackbox",
    "security",
    "gaming",
    "nostale"
  ],
  "author": "Gfless Contributors",
  "license": "MIT",
  "dependencies": {
    "node-addon-api": "^7.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/example/gfless-nodejs.git"
  },
  "bugs": {
    "url": "https://github.com/example/gfless-nodejs/issues"
  },
  "homepage": "https://github.com/example/gfless-nodejs#readme"
}